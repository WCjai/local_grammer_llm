<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glass edge highlight (bright white border — mimics light catching glass edge) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1.5dp"
                android:color="#80FFFFFF" />
        </shape>
    </item>
    <!-- Frosted glass fill (translucent white — card-level blur shows through) -->
    <item
        android:top="1dp"
        android:left="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="27dp" />
        </shape>
    </item>
</layer-list>
