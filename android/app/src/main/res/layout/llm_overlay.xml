<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/llmOverlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    android:background="@android:color/transparent">

    <!-- Loading card (center) -->
    <FrameLayout
        android:id="@+id/loadingCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:padding="20dp"
        android:elevation="6dp">

        <!-- Ultra-minimal: spinner + icon cancel overlayed -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:minWidth="52dp"
                android:minHeight="52dp"
                android:padding="0dp"
                android:text="✕"
                android:textSize="20sp"
                android:textAllCaps="false"
                android:background="@drawable/cancel_circle"
                android:textColor="#FFFFFF"
                android:contentDescription="Cancel"
                android:layout_gravity="center" />
        </FrameLayout>

    </FrameLayout>

    <!-- Preview overlay -->
    <FrameLayout
        android:id="@+id/previewBox"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:id="@+id/previewCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/overlay_card"
            android:orientation="vertical"
            android:elevation="2dp"
            android:padding="0dp">

            <!-- Header -->
            <LinearLayout
                android:id="@+id/previewHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/previewTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Preview"
                    android:textColor="#1A1633"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.01" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:id="@+id/previewDivider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="#18000000" />

            <!-- Content -->
            <ScrollView
                android:id="@+id/previewScroll"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/previewText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#2A2155"
                    android:textSize="15sp"
                    android:lineSpacingExtra="4dp"
                    android:gravity="start"
                    android:textAlignment="viewStart" />
            </ScrollView>

            <!-- Divider -->
            <View
                android:id="@+id/previewDivider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="#18000000" />

            <!-- Actions -->
            <LinearLayout
                android:id="@+id/previewActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnPreviewCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="96dp"
                    android:text="Discard"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/ghost_rect"
                    android:textColor="#6C3FC5"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:contentDescription="Do not apply" />

                <Button
                    android:id="@+id/btnPreviewCopy"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="72dp"
                    android:layout_marginStart="10dp"
                    android:text="Copy"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/ghost_rect"
                    android:textColor="#6C3FC5"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:contentDescription="Copy to clipboard" />

                <Button
                    android:id="@+id/btnPreviewApply"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="96dp"
                    android:layout_marginStart="10dp"
                    android:text="Apply"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/apply_rect"
                    android:textColor="#FFFFFF"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

    <!-- Context overlay -->
    <FrameLayout
        android:id="@+id/contextBox"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="@android:color/transparent"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:id="@+id/contextCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/overlay_card"
            android:orientation="vertical"
            android:elevation="2dp"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingTop="20dp"
                android:paddingEnd="24dp"
                android:paddingBottom="14dp">

                <TextView
                    android:id="@+id/contextTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Add Context"
                    android:textColor="#1A1633"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.01" />
            </LinearLayout>

            <View
                android:id="@+id/contextDivider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="#18000000" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <EditText
                    android:id="@+id/contextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textCapSentences"
                    android:hint="e.g. Replying to a client about a late delivery&#x2026;"
                    android:textColorHint="#8070A0"
                    android:textColor="#2A2155"
                    android:textSize="15sp"
                    android:lineSpacingExtra="3dp"
                    android:background="@android:color/transparent"
                    android:padding="0dp" />
            </ScrollView>

            <!-- Attach screenshot row (shown above action buttons) -->
            <LinearLayout
                android:id="@+id/attachScreenshotRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="8dp"
                android:paddingBottom="4dp">

                <ImageButton
                    android:id="@+id/btnAttachScreenshot"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_image_add"
                    android:background="@drawable/ghost_rect"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:tint="#6C3FC5"
                    android:contentDescription="Attach screenshot" />

                <!-- Thumbnail shown after a screenshot is attached -->
                <FrameLayout
                    android:id="@+id/attachedThumbWrap"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="12dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/attachedThumb"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:scaleType="centerCrop"
                        android:contentDescription="Attached screenshot thumbnail" />

                    <ImageButton
                        android:id="@+id/btnDetachScreenshot"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="top|end"
                        android:src="@drawable/ic_close_small"
                        android:background="@android:color/transparent"
                        android:tint="#FFFFFF"
                        android:contentDescription="Remove screenshot" />

                </FrameLayout>

            </LinearLayout>

            <View
                android:id="@+id/contextDivider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="#18000000" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end|center_vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnContextCancel"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="96dp"
                    android:text="Skip"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/ghost_rect"
                    android:textColor="#6C3FC5"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:contentDescription="Skip context" />

                <Button
                    android:id="@+id/btnContextOk"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="96dp"
                    android:layout_marginStart="10dp"
                    android:text="Add"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/apply_rect"
                    android:textColor="#FFFFFF"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp" />
            </LinearLayout>

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
